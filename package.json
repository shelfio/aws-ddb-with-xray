{
  "name": "@shelf/aws-ddb-with-xray",
  "version": "2.4.1",
  "description": "AWS DynamoDB Document Client initialized with X-Ray",
  "keywords": [
    "aws sdk",
    "document client",
    "dynamodb",
    "x-ray",
    "xray"
  ],
  "repository": "shelfio/aws-ddb-with-xray",
  "license": "MIT",
  "author": {
    "name": "Vlad Holubiev",
    "email": "vlad@shelf.io",
    "url": "shelf.io"
  },
  "main": "lib",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rm -rf lib/ && tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "coverage": "jest --coverage",
    "lint": "oxfmt && eslint . --fix",
    "lint:ci": "oxfmt --check && eslint .",
    "prepack": "pnpm build",
    "test": "jest src --runInBand --forceExit",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "post-commit": "git update-index --again"
    }
  },
  "jest": {
    "preset": "@shelf/jest-dynamodb",
    "transform": {
      "^.+\\.[tj]s$": "babel-jest"
    }
  },
  "dependencies": {
    "@aws/dynamodb-expressions": "0.7.3",
    "aws-xray-sdk-core": "3.12.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@shelf/eslint-config": "6.3.0",
    "@shelf/jest-dynamodb": "4.0.2",
    "@shelf/prettier-config": "1.1.1",
    "@shelf/tsconfig": "0.1.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.2.1",
    "babel-jest": "30.4.1",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "16.2.7",
    "oxfmt": "0.53.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "3.x.x",
    "@aws-sdk/lib-dynamodb": "3.x.x"
  },
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{html,json,md,yml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{ts,js}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ]
  }
}
